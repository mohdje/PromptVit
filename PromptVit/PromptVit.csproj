<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.0.0</Version>                   
    <Authors>mohdje</Authors>
    <Company>mohdje</Company>
    <Description>Easy to use lightweight client multi-provider for LLMs (OpenAI, Google, etc.) with streaming, tool calls and more.</Description>
    <PackageTags>AI;LLM;Prompt;OpenAI;Gemini;Claude;DeepSeek;Qwen;HuggingFace;Cerebras;streaming;tools</PackageTags>
    <PackageProjectUrl>https://github.com/mohdje/PromptVit</PackageProjectUrl>
    <RepositoryUrl>https://github.com/mohdje/PromptVit.git</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression> 
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <GenerateDocumentationFile>true</GenerateDocumentationFile> 
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild> 
  </PropertyGroup>

</Project>
